HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database - Neon PostgreSQL (no pausing!)
DATABASE_CLIENT=postgres
# Connection string from Neon dashboard (recommended)
# Format: postgresql://[username]:[password]@[project]-[org].neon.tech/[dbname]?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your-password@ep-xxxxx-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# SSL is required for Neon
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Optional: For local development, use SQLite
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# Email Configuration - Resend via SMTP
# Sign up at https://resend.com and get your API key
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=resend
EMAIL_SMTP_PASSWORD=re_your_api_key_here
EMAIL_DEFAULT_FROM=onboarding@resend.dev
EMAIL_DEFAULT_REPLY_TO=contact@jooffoundation.org
EMAIL_ADMIN_RECIPIENT=admin@jooffoundation.org
# Optional: Public URL for logo in emails (upload to Strapi media or use production domain)
EMAIL_LOGO_URL=https://your-domain.com/images/joof-logo.png
