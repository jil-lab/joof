{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "healthcare",
        "education",
        "community"
      ]
    },
    "description": {
      "type": "blocks"
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 200
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "features": {
      "type": "json"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "impactStats": {
      "type": "json"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
