{
  "name": "joof-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "npm run dev --workspaces --if-present",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build": "npm run build --workspaces --if-present",
    "guidance": "npx -y modern-web-guidance@latest"
  },
  "overrides": {
    "@strapi/admin": "5.35.0",
    "@strapi/content-manager": "5.35.0",
    "@strapi/content-releases": "5.35.0",
    "@strapi/content-type-builder": "5.35.0",
    "@strapi/core": "5.35.0",
    "@strapi/email": "5.35.0",
    "@strapi/i18n": "5.35.0",
    "@strapi/review-workflows": "5.35.0",
    "@strapi/upload": "5.35.0",
    "@strapi/utils": "5.35.0",
    "@strapi/database": "5.35.0"
  }
}
